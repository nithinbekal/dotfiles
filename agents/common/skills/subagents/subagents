#!/usr/bin/env bash
#
# subagents — run helper agents in a dedicated tmux window and talk to them.
#
# Each subagent is an interactive `pi` running in its own pane of a tmux window
# named "subagents". You hand a subagent a task, watch it work, send it
# follow-ups (answers / steering / nudges), and collect its final report.
#
# Subagents start with built-in tools only (--no-extensions) so they boot fast
# and clean. The lead drives everything over tmux send-keys + capture-pane.
#
# Launcher: subagents are started with `$SUBAGENTS_PI` (default "pi"). If your
# model provider needs a wrapper command to inject auth, set SUBAGENTS_PI in a
# private file such as ~/.zshrc.local, e.g.  export SUBAGENTS_PI="some-wrapper pi"
#
# Roles: markdown files with optional YAML frontmatter (`model`, `tools`) whose
# body becomes the subagent's system prompt. Looked up in $SUBAGENTS_ROLE_DIRS
# (colon-separated), else ~/.pi/agent/agents then ./.pi/agents.
#
# Usage:
#   subagents run [-m MODEL] [--effort LEVEL] <role> <task...>
#                                       Start a subagent from a role, give it the task. Prints its id.
#                                       -m/--model overrides the role's model (use a provider-qualified
#                                       id, e.g. anthropic/claude-sonnet-4-6). --effort sets the
#                                       thinking level (off|minimal|low|medium|high|xhigh).
#   subagents tell <id> <message...>    Send a follow-up message to a subagent.
#   subagents wait <id> [seconds]       Block until it finishes its task; print its report.
#   subagents events                    Print NEW completion events as TSV (id\trole\tstatus\treportPath). Non-blocking. For the watcher extension.
#   subagents reap                      Print any newly-finished reports (non-blocking, human-friendly).
#   subagents status                    Show each subagent as working|idle|exited (non-blocking, no consume).
#   subagents peek <id> [lines]         Show the tail of a subagent's pane (watch it work).
#   subagents ls                        List active subagents.
#   subagents stop <id|--all>           Shut a subagent (or all) down (window closes when empty).
#   subagents roles                     List available role files.

set -uo pipefail

PI_CMD="${SUBAGENTS_PI:-pi}"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/subagents"
ROLE_DIRS="${SUBAGENTS_ROLE_DIRS:-$HOME/.pi/agent/agents:$PWD/.pi/agents}"
WIN_PREFIX="subagents"
SENTINEL="@@DONE@@"
DEFAULT_WAIT=120
IDLE_POLLS=6   # consecutive unchanged polls before a subagent counts as idle

mkdir -p "$STATE_DIR"

die() { echo "subagents: $*" >&2; exit 1; }
in_tmux() { [ -n "${TMUX:-}" ]; }

# ---- role files -----------------------------------------------------------

role_file() {
	local role="$1" dir f
	IFS=: read -r -a dirs <<<"$ROLE_DIRS"
	for dir in "${dirs[@]}"; do
		f="$dir/$role.md"
		[ -f "$f" ] && { echo "$f"; return 0; }
	done
	return 1
}

# Print the YAML frontmatter block (between the first two --- lines).
_frontmatter() { awk 'NR==1 && $0=="---"{f=1;next} f && $0=="---"{exit} f{print}' "$1"; }

# Get a scalar frontmatter field, stripped of quotes.
fm_get() {
	_frontmatter "$1" | sed -n "s/^$2:[[:space:]]*//p" | head -1 | sed "s/^[\"']//; s/[\"']$//"
}

# Print the role body (everything after the frontmatter, or the whole file).
role_body() {
	awk 'NR==1 && $0=="---"{infm=1;next} infm && $0=="---"{infm=0;next} !infm{print}' "$1"
}

# Normalize a tools value ("[a, b]" or "a, b") into "a,b".
normalize_tools() {
	echo "$1" | tr -d '[]' | tr ',' '\n' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | grep -v '^$' | paste -sd, -
}

# ---- tmux window / pane helpers -------------------------------------------

current_session() {
	tmux display-message -pt "${TMUX_PANE:-}" '#{session_name}' 2>/dev/null \
		|| tmux display-message -p '#{session_name}'
}

# Session scoping: every command only sees subagents in the CURRENT tmux session.
_CUR_SID=""
cur_sid() {
	[ -n "$_CUR_SID" ] || _CUR_SID=$(tmux display-message -pt "${TMUX_PANE:-}" '#{session_id}' 2>/dev/null)
	printf '%s' "$_CUR_SID"
}
pane_sid() { # pane_id -> session_id of that pane
	tmux list-panes -a -F '#{pane_id} #{session_id}' 2>/dev/null | awk -v p="$1" '$1==p{print $2; exit}'
}
# True when subagent <id> belongs to the current session. Uses the stored sid
# (so it still scopes correctly after the pane dies); falls back to the pane's
# live location for subagents spawned before sid tagging existed.
in_session() { # id
	local sid; sid=$(cat "$STATE_DIR/$1/sid" 2>/dev/null)
	[ -n "$sid" ] || sid=$(pane_sid "$(cat "$STATE_DIR/$1/pane" 2>/dev/null)")
	[ -n "$sid" ] && [ "$sid" = "$(cur_sid)" ]
}

subagents_window() { # session -> window_id of the subagents window (or empty)
	tmux list-windows -t "$1" -F '#{window_id} #{window_name}' 2>/dev/null \
		| awk -v p="$WIN_PREFIX" '$2==p || index($2, p" (")==1 {print $1; exit}'
}

pane_alive() { # pane_id
	tmux list-panes -a -F '#{pane_id} #{pane_dead}' 2>/dev/null \
		| awk -v p="$1" '$1==p{print $2}' | grep -qx 0
}

send_pane() { # pane_id message...
	local pane="$1"; shift
	local msg="$*"
	msg=${msg//$'\n'/ }   # collapse newlines: a bare Enter submits in pi
	tmux send-keys -t "$pane" -l -- "$msg"
	sleep 0.3
	tmux send-keys -t "$pane" Enter
}

file_mtime() { # path -> mtime epoch; works with GNU coreutils or BSD stat
	local m
	m=$(stat -c %Y "$1" 2>/dev/null) || m=$(stat -f %m "$1" 2>/dev/null) || m=0
	case "$m" in '' | *[!0-9]*) m=0 ;; esac
	printf '%s\n' "$m"
}

next_id() {
	local seq="$STATE_DIR/.seq" n
	n=$(cat "$seq" 2>/dev/null || echo 0)
	n=$((n + 1))
	echo "$n" >"$seq"
	echo "$n"
}

write_protocol() { # result_path
	cat <<EOF
# Subagent protocol (important)

You are an autonomous helper running in a tmux pane. A lead agent sends you a
task and may send follow-up messages. Work autonomously; do not ask for
confirmation on routine steps.

The lead CANNOT see your screen. The only way it receives your work is the file
below, so you MUST end every task by writing to it:

1. Write your complete final answer/report to this file, overwriting it each task:
   $1
2. Then print a single line containing exactly: $SENTINEL
3. Then stop and wait for the next message, repeating these steps each time.

Never answer only in chat — always write the file first. If you get blocked and
need the lead's input, write what you need (plus any partial findings) to the
file, print $SENTINEL, and wait for the reply.
EOF
}

# ---- completion detection (shared by wait / events / reap) ----------------

# Snapshot a report to reports/<n>.md and echo its path. Copies $2 (a file) when
# non-empty, otherwise captures the pane tail. Makes each event immutable.
snapshot() { # id source-file-or-empty
	local id="$1" src="$2" dir="$STATE_DIR/$id" n out
	n=$(cat "$dir/revent" 2>/dev/null || echo 0); n=$((n + 1)); echo "$n" >"$dir/revent"
	mkdir -p "$dir/reports"; out="$dir/reports/$n.md"
	if [ -n "$src" ] && [ -s "$src" ]; then
		cp "$src" "$out"
	else
		tmux capture-pane -p -t "$(cat "$dir/pane")" 2>/dev/null | grep -v '^[[:space:]]*$' | tail -40 >"$out"
	fi
	echo "$out"
}

# Detect a NEW completion for one subagent. On a new event, advance its markers
# and print a TSV line: "<id>\t<role>\t<status>\t<reportPath>" (status = done |
# idle | exited), returning 0. Otherwise print nothing and return 1.
# Used on-demand by `reap`/`events` and in a loop by `wait`.
detect_and_emit() { # id
	local id="$1" dir="$STATE_DIR/$id"
	[ -d "$dir" ] && [ -f "$dir/pane" ] || return 1
	local pane role; pane=$(cat "$dir/pane"); role=$(cat "$dir/role" 2>/dev/null)

	if ! pane_alive "$pane"; then
		[ -f "$dir/.exited" ] && return 1
		: >"$dir/.exited"
		printf '%s\t%s\t%s\t%s\n' "$id" "$role" "exited" "$(snapshot "$id" "$dir/result.md")"
		return 0
	fi

	# clean completion: a new sentinel printed, or result.md freshly written
	local rcount rmtime count mtime
	rcount=$(cat "$dir/rcount" 2>/dev/null || echo 0)
	rmtime=$(cat "$dir/rmtime" 2>/dev/null || echo 0)
	count=$(tmux capture-pane -p -S - -t "$pane" 2>/dev/null | grep -c -- "$SENTINEL"); count=${count:-0}
	mtime=$(file_mtime "$dir/result.md")
	if [ "$count" -gt "$rcount" ] || { [ -s "$dir/result.md" ] && [ "$mtime" -gt "$rmtime" ]; }; then
		echo "$count" >"$dir/rcount"; echo "$mtime" >"$dir/rmtime"
		echo 0 >"$dir/stable"; echo 0 >"$dir/saw"
		tmux capture-pane -p -t "$pane" 2>/dev/null | cksum >"$dir/rphash"
		printf '%s\t%s\t%s\t%s\n' "$id" "$role" "done" "$(snapshot "$id" "$dir/result.md")"
		return 0
	fi

	# idle fallback (stateful across calls): answered inline / waiting. Only fires
	# after we've seen activity and the pane differs from the last reported state.
	local lhash stable saw rphash cur
	lhash=$(cat "$dir/lhash" 2>/dev/null || echo "")
	stable=$(cat "$dir/stable" 2>/dev/null || echo 0)
	saw=$(cat "$dir/saw" 2>/dev/null || echo 0)
	rphash=$(cat "$dir/rphash" 2>/dev/null || echo "")
	cur=$(tmux capture-pane -p -t "$pane" 2>/dev/null | cksum)
	if [ "$cur" != "$lhash" ]; then stable=0; saw=1; else stable=$((stable + 1)); fi
	echo "$cur" >"$dir/lhash"; echo "$stable" >"$dir/stable"; echo "$saw" >"$dir/saw"
	# Only an INLINE answer counts as an idle event: no result file was written,
	# the pane has gone quiet, and it shows substantive (non-banner) content.
	if [ "$stable" -ge "$IDLE_POLLS" ] && [ "$saw" = 1 ] && [ "$cur" != "$rphash" ] && [ ! -s "$dir/result.md" ]; then
		local cap meaningful
		cap=$(tmux capture-pane -p -t "$pane" 2>/dev/null | grep -v '^[[:space:]]*$')
		meaningful=$(printf '%s\n' "$cap" | grep -vcE '^[[:space:]]*[][(){}<>=_~|*-]*[─│]*[[:space:]]*$|pi v[0-9]|Package Updates|Press ctrl|escape interrupt|Model scope|Pi can explain|Update Available|Changelog|Run pi update|^\[(Context|Themes|Skills|Prompts)\]')
		if [ "${meaningful:-0}" -ge 3 ]; then
			echo "$cur" >"$dir/rphash"; echo 0 >"$dir/saw"
			local n out; n=$(cat "$dir/revent" 2>/dev/null || echo 0); n=$((n + 1)); echo "$n" >"$dir/revent"
			mkdir -p "$dir/reports"; out="$dir/reports/$n.md"
			printf '%s\n' "$cap" | tail -40 >"$out"
			printf '%s\t%s\t%s\t%s\n' "$id" "$role" "idle" "$out"
			return 0
		fi
	fi
	return 1
}

# ---- commands -------------------------------------------------------------

cmd_run() {
	local model_override="" effort_override=""
	while [ $# -gt 0 ]; do
		case "$1" in
			-m|--model) model_override="${2:-}"; shift 2 || die "-m needs a value" ;;
			--effort) effort_override="${2:-}"; shift 2 || die "--effort needs a value" ;;
			--) shift; break ;;
			-*) die "unknown option '$1'" ;;
			*) break ;;
		esac
	done
	local role="${1:-}"; shift || true
	local task="$*"
	[ -n "$role" ] && [ -n "$task" ] || die "usage: subagents run [-m MODEL] [--effort LEVEL] <role> <task...>"
	in_tmux || die "subagents requires tmux"

	local rf; rf=$(role_file "$role") || die "role '$role' not found (try: subagents roles)"

	local sess; sess=$(current_session)
	local id; id=$(next_id)
	local dir="$STATE_DIR/$id"; mkdir -p "$dir"
	local result="$dir/result.md"
	: >"$result"

	role_body "$rf" >"$dir/role.md"
	write_protocol "$result" >"$dir/protocol.md"

	local model tools modelflag="" toolsflag="" thinkflag=""
	# model precedence: -m flag > role frontmatter > launcher default
	model=$(fm_get "$rf" model)
	[ -n "$model_override" ] && model="$model_override"
	tools=$(fm_get "$rf" tools)
	[ -n "$model" ] && [ "$model" != "inherit" ] && modelflag="--model $model"
	[ -n "$effort_override" ] && thinkflag="--thinking $effort_override"
	if [ -n "$tools" ]; then
		# always allow `write` so the subagent can produce its report file
		toolsflag="--tools $(normalize_tools "$tools"),write"
	fi

	local q_pwd q_role q_proto q_task
	q_pwd=$(printf %q "$PWD")
	q_role=$(printf %q "$dir/role.md")
	q_proto=$(printf %q "$dir/protocol.md")
	q_task=$(printf %q "${task//$'\n'/ }")

	local picmd="cd $q_pwd && exec $PI_CMD --no-extensions --no-skills --no-prompt-templates --no-session"
	[ -n "$modelflag" ] && picmd="$picmd $modelflag"
	[ -n "$thinkflag" ] && picmd="$picmd $thinkflag"
	[ -n "$toolsflag" ] && picmd="$picmd $toolsflag"
	picmd="$picmd --append-system-prompt $q_role --append-system-prompt $q_proto $q_task"

	local pane win
	win=$(subagents_window "$sess")
	if [ -z "$win" ]; then
		pane=$(tmux new-window -d -t "$sess" -n "$WIN_PREFIX" -P -F '#{pane_id}' "$picmd")
	else
		pane=$(tmux split-window -d -t "$win" -P -F '#{pane_id}' "$picmd")
		tmux select-layout -t "$win" tiled >/dev/null 2>&1 || true
	fi

	echo "$pane" >"$dir/pane"
	printf '%s\n' "$(cur_sid)" >"$dir/sid"
	echo "$role" >"$dir/role"
	echo "$task" >"$dir/task"
	echo 0 >"$dir/rcount"
	echo 0 >"$dir/rmtime"
	date +%s >"$dir/sent"
	tmux select-pane -t "$pane" -T "subagent#$id $role" 2>/dev/null || true

	echo "started subagent #$id ($role) — pane $pane, model ${model:-inherited}${effort_override:+, effort $effort_override}"
	echo "  watch:   subagents peek $id"
	echo "  answer:  subagents tell $id <message>"
	echo "  collect: subagents wait $id"
}

cmd_tell() {
	local id="${1:-}"; shift || true
	local msg="$*"
	[ -n "$id" ] && [ -n "$msg" ] || die "usage: subagents tell <id> <message...>"
	local dir="$STATE_DIR/$id"; [ -d "$dir" ] || die "no subagent #$id"
	in_session "$id" || die "subagent #$id is in another tmux session"
	local pane; pane=$(cat "$dir/pane")
	pane_alive "$pane" || die "subagent #$id is not running"
	date +%s >"$dir/sent"
	send_pane "$pane" "$msg"
	echo "sent to subagent #$id"
}

cmd_wait() {
	local id="${1:-}"; local secs="${2:-$DEFAULT_WAIT}"
	[ -n "$id" ] || die "usage: subagents wait <id> [seconds]"
	[ -d "$STATE_DIR/$id" ] || die "no subagent #$id"
	in_session "$id" || die "subagent #$id is in another tmux session"
	local i line status path
	for ((i = 0; i < secs; i += 2)); do
		if line=$(detect_and_emit "$id") && [ -n "$line" ]; then
			IFS=$'\t' read -r _ _ status path <<<"$line"
			echo "=== subagent #$id report ($status) ==="
			[ -s "$path" ] && cat "$path" || echo "(no report captured)"
			return 0
		fi
		sleep 2
	done
	echo "[subagent #$id still working after ${secs}s — 'subagents peek $id' to watch, 'subagents tell $id <msg>' to steer]"
	return 1
}

# Print NEW completion events across all subagents as TSV (one pass, non-blocking).
cmd_events() {
	local dir id
	for dir in "$STATE_DIR"/*/; do
		[ -d "$dir" ] || continue
		id=$(basename "$dir"); [ -f "$dir/pane" ] || continue
		in_session "$id" || continue
		detect_and_emit "$id" || true
	done
}

# Human-friendly drain of newly-finished reports.
cmd_reap() {
	local any=0 id role status path
	while IFS=$'\t' read -r id role status path; do
		[ -n "$id" ] || continue
		any=1
		echo "=== subagent #$id ($role) — $status ==="
		[ -s "$path" ] && cat "$path" || echo "(no report captured)"
		echo
	done < <(cmd_events)
	[ "$any" = 1 ] || echo "no new reports"
}

# Non-blocking live status of each subagent (does not consume events).
cmd_status() {
	local dir id pane role st found=0 h1 h2
	for dir in "$STATE_DIR"/*/; do
		[ -d "$dir" ] || continue
		id=$(basename "$dir"); [ -f "$dir/pane" ] || continue
		in_session "$id" || continue
		pane=$(cat "$dir/pane"); role=$(cat "$dir/role" 2>/dev/null)
		if ! pane_alive "$pane"; then
			st="exited"
		else
			h1=$(tmux capture-pane -p -t "$pane" 2>/dev/null | cksum); sleep 0.4
			h2=$(tmux capture-pane -p -t "$pane" 2>/dev/null | cksum)
			[ "$h1" = "$h2" ] && st="idle" || st="working"
		fi
		printf "#%-3s %-14s %s\n" "$id" "$role" "$st"; found=1
	done
	[ "$found" = 1 ] || echo "no subagents"
}

cmd_peek() {
	local id="${1:-}"; local lines="${2:-40}"
	[ -n "$id" ] || die "usage: subagents peek <id> [lines]"
	local dir="$STATE_DIR/$id"; [ -d "$dir" ] || die "no subagent #$id"
	in_session "$id" || die "subagent #$id is in another tmux session"
	local pane; pane=$(cat "$dir/pane")
	pane_alive "$pane" || { echo "[subagent #$id not running]"; return 0; }
	tmux capture-pane -p -t "$pane" | grep -v '^[[:space:]]*$' | tail -"$lines"
}

cmd_ls() {
	local dir id pane role st task found=0
	for dir in "$STATE_DIR"/*/; do
		[ -d "$dir" ] || continue
		id=$(basename "$dir")
		[ -f "$dir/pane" ] || continue
		in_session "$id" || continue
		pane=$(cat "$dir/pane")
		role=$(cat "$dir/role" 2>/dev/null)
		if pane_alive "$pane"; then st="alive"; else st="dead"; fi
		task=$(head -c 64 "$dir/task" 2>/dev/null | tr '\n' ' ')
		printf "#%-3s %-14s %-6s %s\n" "$id" "$role" "$st" "$task"
		found=1
	done
	[ "$found" = 1 ] || echo "no subagents"
}

cmd_stop() {
	local target="${1:-}"
	[ -n "$target" ] || die "usage: subagents stop <id|--all>"
	if [ "$target" = "--all" ]; then
		local dir id pane
		for dir in "$STATE_DIR"/*/; do
			[ -d "$dir" ] || continue
			id=$(basename "$dir")
			[ -f "$dir/pane" ] || continue
			in_session "$id" || continue
			pane=$(cat "$dir/pane")
			tmux kill-pane -t "$pane" 2>/dev/null || true
			rm -rf "$dir"
			echo "stopped subagent #$id"
		done
	else
		local dir="$STATE_DIR/$target"; [ -d "$dir" ] || die "no subagent #$target"
		in_session "$target" || die "subagent #$target is in another tmux session"
		local pane; pane=$(cat "$dir/pane")
		tmux kill-pane -t "$pane" 2>/dev/null || true
		rm -rf "$dir"
		echo "stopped subagent #$target"
	fi
}

cmd_roles() {
	local dir f name model
	IFS=: read -r -a dirs <<<"$ROLE_DIRS"
	for dir in "${dirs[@]}"; do
		[ -d "$dir" ] || continue
		echo "# $dir"
		for f in "$dir"/*.md; do
			[ -f "$f" ] || continue
			name=$(basename "$f" .md)
			model=$(fm_get "$f" model)
			printf "  %-20s %s\n" "$name" "${model:+($model)}"
		done
	done
}

usage() { awk 'NR>1 && /^#/{sub(/^# ?/,""); print; next} NR>1 && !/^#/{exit}' "$0"; }

# ---- dispatch -------------------------------------------------------------

cmd="${1:-}"; shift || true
case "$cmd" in
	run)       cmd_run   "$@" ;;
	tell)      cmd_tell  "$@" ;;
	wait)      cmd_wait  "$@" ;;
	events)    cmd_events "$@" ;;
	reap)      cmd_reap  "$@" ;;
	status)    cmd_status "$@" ;;
	peek)      cmd_peek  "$@" ;;
	ls|list)   cmd_ls    "$@" ;;
	stop|kill) cmd_stop  "$@" ;;
	roles)     cmd_roles "$@" ;;
	""|-h|--help|help) usage ;;
	*) die "unknown command '$cmd' (try: subagents --help)" ;;
esac
