#!/usr/bin/env bash
#
# subagents — run helper agents in a dedicated tmux window and talk to them.
#
# Each subagent is an interactive `pi` running in its own pane of a tmux window
# named "subagents". You hand a subagent a task, watch it work, send it
# follow-ups (answers / steering / nudges), and collect its final report.
#
# Subagents start with built-in tools only (--no-extensions) so they boot fast
# and clean. The lead drives everything over tmux send-keys + capture-pane.
#
# Launcher: subagents are started with `$SUBAGENTS_PI` (default "pi"). If your
# model provider needs a wrapper command to inject auth, set SUBAGENTS_PI in a
# private file such as ~/.zshrc.local, e.g.  export SUBAGENTS_PI="some-wrapper pi"
#
# Roles: markdown files with optional YAML frontmatter (`model`, `tools`) whose
# body becomes the subagent's system prompt. Looked up in $SUBAGENTS_ROLE_DIRS
# (colon-separated), else ~/.pi/agent/agents then ./.pi/agents.
#
# Session scoping: each tmux session gets its own subfolder under the state dir
# (named after the tmux session id, e.g. <state>/$3/<id>/), so commands and the
# watcher extension only ever see the current session's subagents — subagents
# spawned in other tmux sessions are invisible and protected.
#
# Usage:
#   subagents doctor                    Validate tmux/state layout, role models, and provider authentication.
#   subagents run [-m MODEL] [--effort LEVEL] <role> <task...>
#                                       Start a subagent from a role, give it the task. Prints its id.
#                                       -m/--model overrides the role's model (use a provider-qualified
#                                       id, e.g. anthropic/claude-sonnet-4-6). --effort sets the
#                                       thinking level (off|minimal|low|medium|high|xhigh).
#   subagents tell <id> <message...>    Send a follow-up message to a subagent.
#   subagents wait <id> [seconds]       Block until it finishes its task; print its report.
#   subagents events                    Print NEW completion events as TSV (id\trole\tstatus\treportPath). Non-blocking. For the watcher extension.
#   subagents reap                      Print any newly-finished reports (non-blocking, human-friendly).
#   subagents status                    Show each subagent as working|idle|exited (non-blocking, no consume).
#   subagents peek <id> [lines]         Show the tail of a subagent's pane (watch it work).
#   subagents ls                        List active subagents.
#   subagents stop <id|--all>           Shut a subagent (or all) down (window closes when empty).
#   subagents roles                     List available role files.

set -uo pipefail

PI_CMD="${SUBAGENTS_PI:-pi}"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/subagents"
ROLE_DIRS="${SUBAGENTS_ROLE_DIRS:-$HOME/.pi/agent/agents:$PWD/.pi/agents}"
WIN_PREFIX="subagents"
SENTINEL="@@DONE@@"
DEFAULT_WAIT=120
IDLE_POLLS=6   # consecutive unchanged polls before a subagent counts as idle

mkdir -p "$STATE_DIR"

die() { echo "subagents: $*" >&2; exit 1; }
in_tmux() { [ -n "${TMUX:-}" ]; }

# ---- role files -----------------------------------------------------------

role_file() {
	local role="$1" dir f
	IFS=: read -r -a dirs <<<"$ROLE_DIRS"
	for dir in "${dirs[@]}"; do
		f="$dir/$role.md"
		[ -f "$f" ] && { echo "$f"; return 0; }
	done
	return 1
}

# Print the YAML frontmatter block (between the first two --- lines).
_frontmatter() { awk 'NR==1 && $0=="---"{f=1;next} f && $0=="---"{exit} f{print}' "$1"; }

# Get a scalar frontmatter field, stripped of quotes.
fm_get() {
	_frontmatter "$1" | sed -n "s/^$2:[[:space:]]*//p" | head -1 | sed "s/^[\"']//; s/[\"']$//"
}

# Print the role body (everything after the frontmatter, or the whole file).
role_body() {
	awk 'NR==1 && $0=="---"{infm=1;next} infm && $0=="---"{infm=0;next} !infm{print}' "$1"
}

# Normalize a tools value ("[a, b]" or "a, b") into "a,b".
normalize_tools() {
	echo "$1" | tr -d '[]' | tr ',' '\n' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | grep -v '^$' | paste -sd, -
}

# ---- tmux window / pane helpers -------------------------------------------

# Absolute path to a subagent's state dir within the current session.
sadir() { # id -> "$SR/<id>"
	local id="$1"
	[ -n "$id" ] || die "internal error: empty subagent id"
	printf '%s/%s' "$(sr)" "$id"
}

# Session scoping: state is partitioned into a per-session subfolder named after
# the tmux session id (e.g. $STATE_DIR/$3/<id>/), so every command — and the
# watcher extension — only ever sees subagents in the CURRENT tmux session. No
# cross-session leakage is possible, because other sessions' subagents live in
# sibling folders that nothing iterates into.
#
# Resolve the session id robustly: from $TMUX_PANE (targets the exact pane we
# run in), then from $TMUX ("socket,pid,<session-num>" -> "$<num>"), then last
# resort the active session. The $TMUX_PANE path is the reliable one; the others
# cover contexts where it is unset.
_CUR_SID=""
cur_sid() {
	[ -n "$_CUR_SID" ] && { printf '%s' "$_CUR_SID"; return 0; }
	if [ -n "${TMUX_PANE:-}" ]; then
		_CUR_SID=$(tmux display-message -pt "$TMUX_PANE" '#{session_id}' 2>/dev/null)
	fi
	if [ -z "$_CUR_SID" ] && [ -n "${TMUX:-}" ]; then
		local num; num=$(printf '%s' "$TMUX" | awk -F, '{print $3}')
		case "$num" in ''|*[!0-9]*) ;; *) _CUR_SID=\$"$num" ;; esac
	fi
	[ -n "$_CUR_SID" ] || _CUR_SID=$(tmux display-message -p '#{session_id}' 2>/dev/null)
	printf '%s' "$_CUR_SID"
}
# Cached absolute path to the current session's state folder (created on demand).
# Cached so the per-call mkdir only happens once; sr() is safe to call in loops.
_SR=""
sr() {
	[ -n "$_SR" ] && { printf '%s' "$_SR"; return 0; }
	local sid; sid=$(cur_sid)
	[ -n "$sid" ] || die "cannot determine current tmux session"
	_SR="$STATE_DIR/$sid"; mkdir -p "$_SR"
	printf '%s' "$_SR"
}

subagents_windows() { # session -> all matching window ids
	tmux list-windows -t "$1" -F '#{window_id} #{window_name}' 2>/dev/null \
		| awk -v p="$WIN_PREFIX" '$2==p || index($2, p" (")==1 {print $1}'
}

subagents_window() { # session -> first matching window id (or empty)
	subagents_windows "$1" | head -1
}

pane_alive() { # pane_id
	tmux list-panes -a -F '#{pane_id} #{pane_dead}' 2>/dev/null \
		| awk -v p="$1" '$1==p{print $2}' | grep -qx 0
}

send_pane() { # pane_id message...
	local pane="$1"; shift
	local msg="$*"
	msg=${msg//$'\n'/ }   # collapse newlines: a bare Enter submits in pi
	tmux send-keys -t "$pane" -l -- "$msg"
	sleep 0.3
	tmux send-keys -t "$pane" Enter
}

file_mtime() { # path -> mtime epoch; works with GNU coreutils or BSD stat
	local m
	m=$(stat -c %Y "$1" 2>/dev/null) || m=$(stat -f %m "$1" 2>/dev/null) || m=0
	case "$m" in '' | *[!0-9]*) m=0 ;; esac
	printf '%s\n' "$m"
}

seq_lock_is_stale() { # lock-dir -> true when old enough and owner is dead/missing
	local lock="$1" pid started mtime now
	[ -d "$lock" ] || return 1
	mtime=$(file_mtime "$lock"); now=$(date +%s)
	[ $((now - mtime)) -ge 3 ] || return 1
	read -r pid started <"$lock/owner" 2>/dev/null || return 0
	case "$pid" in ''|*[!0-9]*) return 0 ;; esac
	! kill -0 "$pid" 2>/dev/null
}

# Reserve a monotonically increasing id. The persistent counter survives
# `stop`/`stop --all`, so a later subagent never reuses an earlier incarnation's
# id. The lock serializes concurrent launchers; gaps after crashes are harmless.
reserve_id() {
	local root lock attempts=0 seq max dir name candidate tmp q_lock stale owner_pid
	root=$(sr); lock="$root/.seq.lock"
	until mkdir "$lock" 2>/dev/null; do
		if seq_lock_is_stale "$lock"; then
			stale="$root/.seq.lock.stale.${BASHPID:-$$}.$RANDOM"
			if mv "$lock" "$stale" 2>/dev/null; then rm -rf "$stale"; fi
			continue
		fi
		attempts=$((attempts + 1))
		[ "$attempts" -lt 200 ] || die "timed out waiting for subagent id lock"
		sleep 0.05
	done
	q_lock=$(printf %q "$lock")
	trap "rm -rf $q_lock 2>/dev/null || true" EXIT HUP INT TERM
	owner_pid=${BASHPID:-$$}
	printf '%s %s\n' "$owner_pid" "$(date +%s)" >"$lock/owner" || die "could not record subagent id lock owner"

	seq=$(cat "$root/.seq" 2>/dev/null || echo 0)
	case "$seq" in ''|*[!0-9]*) seq=0 ;; esac
	# Migration: never allocate below ids created before the counter existed.
	max=$seq
	for dir in "$root"/[0-9]*/; do
		[ -d "$dir" ] || continue
		name=$(basename "$dir")
		case "$name" in *[!0-9]*|'') continue ;; esac
		[ "$name" -gt "$max" ] && max="$name"
	done

	while :; do
		candidate=$((max + 1)); tmp="$root/.seq.tmp.$$.$RANDOM"
		printf '%s\n' "$candidate" >"$tmp" || die "could not persist subagent id counter"
		mv "$tmp" "$root/.seq" || die "could not persist subagent id counter"
		if mkdir "$root/$candidate" 2>/dev/null; then break; fi
		max=$candidate
	done

	trap - EXIT HUP INT TERM
	rm -rf "$lock" 2>/dev/null || true
	printf '%s\n' "$candidate"
}

# Serialise the lookup/create/split sequence. In particular, a caller that saw
# no window before waiting on the lock must re-check under the lock and reuse a
# window created by the winner instead of creating a duplicate.
create_subagent_pane() { # session command
	local sess="$1" picmd="$2" lock q_lock win pane attempts=0
	lock="$(sr)/.window-lock"
	until mkdir "$lock" 2>/dev/null; do
		attempts=$((attempts + 1))
		[ "$attempts" -lt 200 ] || die "timed out waiting for subagents window lock"
		sleep 0.05
	done
	q_lock=$(printf %q "$lock")
	trap "rmdir $q_lock 2>/dev/null || true" EXIT
	trap 'exit 1' HUP INT TERM

	win=$(subagents_window "$sess")
	if [ -z "$win" ]; then
		pane=$(tmux new-window -d -t "$sess" -n "$WIN_PREFIX" -P -F '#{pane_id}' "$picmd") || return 1
	else
		pane=$(tmux split-window -d -t "$win" -P -F '#{pane_id}' "$picmd") || return 1
		tmux select-layout -t "$win" tiled >/dev/null 2>&1 || true
	fi
	rmdir "$lock" 2>/dev/null || true
	trap - EXIT HUP INT TERM
	printf '%s\n' "$pane"
}

write_protocol() { # result_path
	cat <<EOF
# Subagent protocol (important)

You are an autonomous helper running in a tmux pane. A lead agent sends you a
task and may send follow-up messages. Work autonomously; do not ask for
confirmation on routine steps.

The lead CANNOT see your screen. The only way it receives your work is the file
below, so you MUST end every task by writing to it:

1. Write your complete final answer/report to this file, overwriting it each task:
   $1
2. Then print a single line containing exactly: $SENTINEL
3. Then stop and wait for the next message, repeating these steps each time.

Never answer only in chat — always write the file first. If you get blocked and
need the lead's input, write what you need (plus any partial findings) to the
file, print $SENTINEL, and wait for the reply.
EOF
}

# ---- completion detection (shared by wait / events / reap) ----------------

# Snapshot a report to reports/<n>.md and echo its path. Copies $2 (a file) when
# non-empty, otherwise captures the pane tail. Makes each event immutable.
snapshot() { # id source-file-or-empty
	local id="$1" src="$2" dir; dir=$(sadir "$id")
	n=$(cat "$dir/revent" 2>/dev/null || echo 0); n=$((n + 1)); echo "$n" >"$dir/revent"
	mkdir -p "$dir/reports"; out="$dir/reports/$n.md"
	if [ -n "$src" ] && [ -s "$src" ]; then
		cp "$src" "$out"
	else
		tmux capture-pane -p -t "$(cat "$dir/pane")" 2>/dev/null | grep -v '^[[:space:]]*$' | tail -40 >"$out"
	fi
	echo "$out"
}

# Detect a NEW completion for one subagent and print a TSV line:
#   "<id>\t<role>\t<status>\t<reportPath>"   (status = done | idle | exited)
# Returns 0 when an event was emitted, else 1. Idempotent: a given report is
# emitted once (keyed on the result file's content hash). A per-subagent lock
# serialises concurrent pollers (watcher extension + a manual `wait`) so the
# same completion can't be double-emitted.
detect_and_emit() { # id
	local id="$1" dir; dir=$(sadir "$id")
	[ -d "$dir" ] && [ -f "$dir/pane" ] || return 1
	mkdir "$dir/.lock" 2>/dev/null || return 1   # another poller is mid-detect
	local rc=1
	_emit_for "$id" && rc=0
	rmdir "$dir/.lock" 2>/dev/null
	return "$rc"
}

_emit_for() { # id  (runs holding $dir/.lock)
	local id="$1" dir; dir=$(sadir "$id")
	local pane role; pane=$(cat "$dir/pane"); role=$(cat "$dir/role" 2>/dev/null)

	if ! pane_alive "$pane"; then
		[ -f "$dir/.exited" ] && return 1
		: >"$dir/.exited"
		printf '%s\t%s\t%s\t%s\n' "$id" "$role" "exited" "$(snapshot "$id" "$dir/result.md")"
		return 0
	fi

	# done: result file holds content we haven't reported yet (keyed on content
	# hash, so re-renders / repeated polls never re-emit the same report)
	if [ -s "$dir/result.md" ]; then
		local rhash curhash
		rhash=$(cat "$dir/rhash" 2>/dev/null || echo "")
		curhash=$(cksum <"$dir/result.md" 2>/dev/null)
		if [ "$curhash" != "$rhash" ]; then
			printf '%s' "$curhash" >"$dir/rhash"
			echo 0 >"$dir/stable"; echo 0 >"$dir/saw"
			tmux capture-pane -p -t "$pane" 2>/dev/null | cksum >"$dir/rphash"
			printf '%s\t%s\t%s\t%s\n' "$id" "$role" "done" "$(snapshot "$id" "$dir/result.md")"
			return 0
		fi
	fi

	# idle fallback (stateful across calls): answered inline / waiting. Only fires
	# after we've seen activity and the pane differs from the last reported state.
	local lhash stable saw rphash cur
	lhash=$(cat "$dir/lhash" 2>/dev/null || echo "")
	stable=$(cat "$dir/stable" 2>/dev/null || echo 0)
	saw=$(cat "$dir/saw" 2>/dev/null || echo 0)
	rphash=$(cat "$dir/rphash" 2>/dev/null || echo "")
	cur=$(tmux capture-pane -p -t "$pane" 2>/dev/null | cksum)
	if [ "$cur" != "$lhash" ]; then stable=0; saw=1; else stable=$((stable + 1)); fi
	echo "$cur" >"$dir/lhash"; echo "$stable" >"$dir/stable"; echo "$saw" >"$dir/saw"
	# Only an INLINE answer counts as an idle event: no result file was written,
	# the pane has gone quiet, and it shows substantive (non-banner) content.
	if [ "$stable" -ge "$IDLE_POLLS" ] && [ "$saw" = 1 ] && [ "$cur" != "$rphash" ] && [ ! -s "$dir/result.md" ]; then
		local cap meaningful
		cap=$(tmux capture-pane -p -t "$pane" 2>/dev/null | grep -v '^[[:space:]]*$')
		meaningful=$(printf '%s\n' "$cap" | grep -vcE '^[[:space:]]*[][(){}<>=_~|*-]*[─│]*[[:space:]]*$|pi v[0-9]|Package Updates|Press ctrl|escape interrupt|Model scope|Pi can explain|Update Available|Changelog|Run pi update|^\[(Context|Themes|Skills|Prompts)\]')
		if [ "${meaningful:-0}" -ge 3 ]; then
			echo "$cur" >"$dir/rphash"; echo 0 >"$dir/saw"
			local n out; n=$(cat "$dir/revent" 2>/dev/null || echo 0); n=$((n + 1)); echo "$n" >"$dir/revent"
			mkdir -p "$dir/reports"; out="$dir/reports/$n.md"
			printf '%s\n' "$cap" | tail -40 >"$out"
			printf '%s\t%s\t%s\t%s\n' "$id" "$role" "idle" "$out"
			return 0
		fi
	fi
	return 1
}

# ---- commands -------------------------------------------------------------

provider_model() { # model -> true when provider-qualified
	local model="$1" provider model_id
	provider=${model%%/*}; model_id=${model#*/}
	[ "$provider" != "$model" ] && [ -n "$provider" ] && [ -n "$model_id" ]
}

run_launcher() {
	# Intentional word splitting: SUBAGENTS_PI may be a wrapper plus `pi`.
	# shellcheck disable=SC2086
	$PI_CMD "$@"
}

cmd_doctor() {
	local failures=0 warnings=0 orphan_sessions=0 legacy_dirs=0 sid root count dir name pane pane_sid role_file model provider
	local i found probe_out
	local role_dir="$HOME/.pi/agent/agents"
	local -a models=() model_roles=()
	in_tmux || { echo "FAIL tmux: not in a tmux session"; return 1; }
	sid=$(cur_sid); root=$(sr)

	count=$(subagents_windows "$sid" | awk 'NF{n++} END{print n+0}')
	if [ "$count" -le 1 ]; then
		echo "ok   window: ${count} subagents window(s) in $sid"
	else
		echo "FAIL window: $count subagents windows in $sid (expected at most 1)"
		failures=$((failures + 1))
	fi

	# The watcher resolves exactly $STATE_DIR/<literal tmux session_id>/<numeric id>.
	case "$sid" in \$[0-9]*) ;; *)
		echo "FAIL state: unexpected tmux session id '$sid'"
		failures=$((failures + 1)) ;;
	esac
	for dir in "$STATE_DIR"/*/; do
		[ -d "$dir" ] || continue
		name=$(basename "$dir")
		case "$name" in
			\$[0-9]*)
				if ! tmux list-sessions -F '#{session_id}' 2>/dev/null | grep -Fqx "$name"; then
					orphan_sessions=$((orphan_sessions + 1))
				fi
				;;
			[0-9]*) legacy_dirs=$((legacy_dirs + 1)) ;;
			*)
				echo "FAIL state: unexpected root entry $dir"
				failures=$((failures + 1))
				;;
		esac
	done
	if [ "$legacy_dirs" -gt 0 ]; then
		echo "WARN state: $legacy_dirs stale legacy numeric dir(s) under $STATE_DIR"
		warnings=$((warnings + 1))
	fi
	if [ "$orphan_sessions" -gt 0 ]; then
		echo "WARN state: $orphan_sessions orphaned tmux session dir(s) under $STATE_DIR"
		warnings=$((warnings + 1))
	fi
	if seq_lock_is_stale "$root/.seq.lock"; then
		local lock_pid lock_started
		read -r lock_pid lock_started <"$root/.seq.lock/owner" 2>/dev/null || { lock_pid="?"; lock_started="?"; }
		echo "WARN state: stale subagent id lock (owner pid $lock_pid, started $lock_started)"
		warnings=$((warnings + 1))
	fi
	for dir in "$root"/*/; do
		[ -d "$dir" ] || continue
		name=$(basename "$dir")
		case "$name" in *[!0-9]*|'')
			echo "FAIL state: non-numeric agent dir $dir"
			failures=$((failures + 1)); continue ;;
		esac
		if [ ! -s "$dir/pane" ] || [ ! -f "$dir/role" ] || [ ! -f "$dir/task" ] || [ ! -f "$dir/result.md" ]; then
			echo "FAIL state: incomplete agent dir $dir"
			failures=$((failures + 1)); continue
		fi
		pane=$(cat "$dir/pane")
		pane_sid=$(tmux display-message -pt "$pane" '#{session_id}' 2>/dev/null || true)
		if [ -z "$pane_sid" ]; then
			echo "WARN state: orphaned agent #$name (pane $pane is gone)"
			warnings=$((warnings + 1))
		elif [ "$pane_sid" != "$sid" ]; then
			echo "FAIL state: agent #$name pane belongs to $pane_sid, not $sid"
			failures=$((failures + 1))
		fi
	done
	[ "$failures" -gt 0 ] || echo "ok   state: watcher-compatible layout at $root"

	if [ ! -d "$role_dir" ]; then
		echo "FAIL roles: missing $role_dir"
		failures=$((failures + 1))
	else
		for role_file in "$role_dir"/*.md; do
			[ -f "$role_file" ] || continue
			model=$(fm_get "$role_file" model)
			if ! provider_model "$model"; then
				echo "FAIL role: $(basename "$role_file") model '$model' is not provider-qualified"
				failures=$((failures + 1)); continue
			fi
			found=0
			for ((i = 0; i < ${#models[@]}; i++)); do
				if [ "${models[$i]}" = "$model" ]; then
					model_roles[$i]="${model_roles[$i]},$(basename "$role_file" .md)"
					found=1; break
				fi
			done
			if [ "$found" = 0 ]; then
				models+=("$model"); model_roles+=("$(basename "$role_file" .md)")
			fi
		done
	fi
	[ "${#models[@]}" -gt 0 ] || { echo "FAIL roles: no valid role models found"; failures=$((failures + 1)); }

	for ((i = 0; i < ${#models[@]}; i++)); do
		model=${models[$i]}; provider=${model%%/*}
		if probe_out=$(run_launcher --no-extensions --no-skills --no-prompt-templates --no-context-files \
			--no-session --no-tools --thinking off --model "$model" --print "Reply with OK only." 2>&1); then
			echo "ok   auth: $provider (${model_roles[$i]})"
		else
			probe_out=$(printf '%s\n' "$probe_out" | grep -E 'No API key|not found|[Ee]rror|[Ff]ailed|[Uu]nauthorized' | tail -1)
			echo "FAIL auth: $provider (${model_roles[$i]})${probe_out:+ — $probe_out}"
			failures=$((failures + 1))
		fi
	done

	if [ "$failures" -gt 0 ]; then
		echo "doctor: $failures failure(s), $warnings warning(s)"
		return 1
	fi
	if [ "$warnings" -gt 0 ]; then
		echo "doctor: healthy, $warnings warning(s)"
	else
		echo "doctor: healthy"
	fi
}

cmd_run() {
	local model_override="" effort_override=""
	while [ $# -gt 0 ]; do
		case "$1" in
			-m|--model) model_override="${2:-}"; shift 2 || die "-m needs a value" ;;
			--effort) effort_override="${2:-}"; shift 2 || die "--effort needs a value" ;;
			--) shift; break ;;
			-*) die "unknown option '$1'" ;;
			*) break ;;
		esac
	done
	local role="${1:-}"; shift || true
	local task="$*"
	[ -n "$role" ] && [ -n "$task" ] || die "usage: subagents run [-m MODEL] [--effort LEVEL] <role> <task...>"
	in_tmux || die "subagents requires tmux"

	local rf; rf=$(role_file "$role") || die "role '$role' not found (try: subagents roles)"

	local sess; sess=$(cur_sid)
	local id; id=$(reserve_id) || die "failed to reserve subagent id"
	case "$id" in ''|*[!0-9]*) die "failed to reserve subagent id" ;; esac
	local dir; dir=$(sadir "$id")
	[ -d "$dir" ] || die "failed to reserve subagent id"
	local result="$dir/result.md"
	: >"$result"
	# Immutable run token used by the watcher in its durable delivery id. This
	# also protects against legacy/manual id reuse and tmux session-id reuse.
	LC_ALL=C od -An -N16 -tx1 /dev/urandom | tr -d ' \n' >"$dir/birth" \
		|| { rm -rf "$dir"; die "could not create subagent incarnation token"; }
	[ -s "$dir/birth" ] || { rm -rf "$dir"; die "could not create subagent incarnation token"; }

	role_body "$rf" >"$dir/role.md"
	write_protocol "$result" >"$dir/protocol.md"

	local model tools modelflag="" toolsflag="" thinkflag=""
	# model precedence: -m flag > role frontmatter > launcher default
	model=$(fm_get "$rf" model)
	[ -n "$model_override" ] && model="$model_override"
	tools=$(fm_get "$rf" tools)
	if [ -n "$model" ] && [ "$model" != "inherit" ] && ! provider_model "$model"; then
		rm -rf "$dir"
		die "model '$model' is not provider-qualified (expected provider/model)"
	fi
	[ -n "$model" ] && [ "$model" != "inherit" ] && modelflag="--model $model"
	[ -n "$effort_override" ] && thinkflag="--thinking $effort_override"
	if [ -n "$tools" ]; then
		# always allow `write` so the subagent can produce its report file
		toolsflag="--tools $(normalize_tools "$tools"),write"
	fi

	local q_pwd q_role q_proto q_task
	q_pwd=$(printf %q "$PWD")
	q_role=$(printf %q "$dir/role.md")
	q_proto=$(printf %q "$dir/protocol.md")
	q_task=$(printf %q "${task//$'\n'/ }")

	local picmd="cd $q_pwd && exec $PI_CMD --no-extensions --no-skills --no-prompt-templates --no-session"
	[ -n "$modelflag" ] && picmd="$picmd $modelflag"
	[ -n "$thinkflag" ] && picmd="$picmd $thinkflag"
	[ -n "$toolsflag" ] && picmd="$picmd $toolsflag"
	picmd="$picmd --append-system-prompt $q_role --append-system-prompt $q_proto $q_task"

	local pane
	if ! pane=$(create_subagent_pane "$sess" "$picmd") || [ -z "$pane" ]; then
		rm -rf "$dir"
		die "failed to create subagent pane"
	fi

	echo "$pane" >"$dir/pane"
	printf '%s\n' "$(cur_sid)" >"$dir/sid"
	echo "$role" >"$dir/role"
	echo "$task" >"$dir/task"
	echo 0 >"$dir/rcount"
	echo 0 >"$dir/rmtime"
	date +%s >"$dir/sent"
	tmux select-pane -t "$pane" -T "subagent#$id $role" 2>/dev/null || true

	echo "started subagent #$id ($role) — pane $pane, model ${model:-inherited}${effort_override:+, effort $effort_override}"
	echo "  report:  pushed by subagents-watch — end your turn"
	echo "  answer:  subagents tell $id <message>"
	echo "  fallback without watcher: subagents wait $id"
}

cmd_tell() {
	local id="${1:-}"; shift || true
	local msg="$*"
	[ -n "$id" ] && [ -n "$msg" ] || die "usage: subagents tell <id> <message...>"
	local dir; dir=$(sadir "$id"); [ -d "$dir" ] || die "no subagent #$id"
	local pane; pane=$(cat "$dir/pane")
	pane_alive "$pane" || die "subagent #$id is not running"
	date +%s >"$dir/sent"
	send_pane "$pane" "$msg"
	echo "sent to subagent #$id"
}

cmd_wait() {
	local id="${1:-}"; local secs="${2:-$DEFAULT_WAIT}"
	[ -n "$id" ] || die "usage: subagents wait <id> [seconds]"
	[ -d "$(sadir "$id")" ] || die "no subagent #$id"
	local i line status path
	for ((i = 0; i < secs; i += 2)); do
		if line=$(detect_and_emit "$id") && [ -n "$line" ]; then
			IFS=$'\t' read -r _ _ status path <<<"$line"
			echo "=== subagent #$id report ($status) ==="
			[ -s "$path" ] && cat "$path" || echo "(no report captured)"
			return 0
		fi
		sleep 2
	done
	echo "[subagent #$id still working after ${secs}s — 'subagents peek $id' to watch, 'subagents tell $id <msg>' to steer]"
	return 1
}

# Print NEW completion events for THIS SESSION's subagents as TSV (one pass,
# non-blocking). Iterating the per-session folder is the scoping mechanism —
# other sessions' subagents live in sibling folders and are never visited.
cmd_events() {
	local dir id
	for dir in "$(sr)"/*/; do
		[ -d "$dir" ] || continue
		id=$(basename "$dir"); [ -f "$dir/pane" ] || continue
		detect_and_emit "$id" || true
	done
}

# Human-friendly drain of newly-finished reports.
cmd_reap() {
	local any=0 id role status path
	while IFS=$'\t' read -r id role status path; do
		[ -n "$id" ] || continue
		any=1
		echo "=== subagent #$id ($role) — $status ==="
		[ -s "$path" ] && cat "$path" || echo "(no report captured)"
		echo
	done < <(cmd_events)
	[ "$any" = 1 ] || echo "no new reports"
}

# Non-blocking live status of each subagent (does not consume events).
cmd_status() {
	local dir id pane role st found=0 h1 h2
	for dir in "$(sr)"/*/; do
		[ -d "$dir" ] || continue
		id=$(basename "$dir"); [ -f "$dir/pane" ] || continue
		pane=$(cat "$dir/pane"); role=$(cat "$dir/role" 2>/dev/null)
		if ! pane_alive "$pane"; then
			st="exited"
		else
			h1=$(tmux capture-pane -p -t "$pane" 2>/dev/null | cksum); sleep 0.4
			h2=$(tmux capture-pane -p -t "$pane" 2>/dev/null | cksum)
			[ "$h1" = "$h2" ] && st="idle" || st="working"
		fi
		printf "#%-3s %-14s %s\n" "$id" "$role" "$st"; found=1
	done
	[ "$found" = 1 ] || echo "no subagents"
}

cmd_peek() {
	local id="${1:-}"; local lines="${2:-40}"
	[ -n "$id" ] || die "usage: subagents peek <id> [lines]"
	local dir; dir=$(sadir "$id"); [ -d "$dir" ] || die "no subagent #$id"
	local pane; pane=$(cat "$dir/pane")
	pane_alive "$pane" || { echo "[subagent #$id not running]"; return 0; }
	tmux capture-pane -p -t "$pane" | grep -v '^[[:space:]]*$' | tail -"$lines"
}

cmd_ls() {
	local dir id pane role st task found=0
	for dir in "$(sr)"/*/; do
		[ -d "$dir" ] || continue
		id=$(basename "$dir")
		[ -f "$dir/pane" ] || continue
		pane=$(cat "$dir/pane")
		role=$(cat "$dir/role" 2>/dev/null)
		if pane_alive "$pane"; then st="alive"; else st="dead"; fi
		task=$(head -c 64 "$dir/task" 2>/dev/null | tr '\n' ' ')
		printf "#%-3s %-14s %-6s %s\n" "$id" "$role" "$st" "$task"
		found=1
	done
	[ "$found" = 1 ] || echo "no subagents"
}

cmd_stop() {
	local target="${1:-}"
	[ -n "$target" ] || die "usage: subagents stop <id|--all>"
	if [ "$target" = "--all" ]; then
		local dir id pane
		for dir in "$(sr)"/*/; do
			[ -d "$dir" ] || continue
			id=$(basename "$dir")
			[ -f "$dir/pane" ] || continue
			pane=$(cat "$dir/pane")
			tmux kill-pane -t "$pane" 2>/dev/null || true
			rm -rf "$dir"
			echo "stopped subagent #$id"
		done
	else
		local dir; dir=$(sadir "$target"); [ -d "$dir" ] || die "no subagent #$target"
		local pane; pane=$(cat "$dir/pane")
		tmux kill-pane -t "$pane" 2>/dev/null || true
		rm -rf "$dir"
		echo "stopped subagent #$target"
	fi
}

cmd_roles() {
	local dir f name model
	IFS=: read -r -a dirs <<<"$ROLE_DIRS"
	for dir in "${dirs[@]}"; do
		[ -d "$dir" ] || continue
		echo "# $dir"
		for f in "$dir"/*.md; do
			[ -f "$f" ] || continue
			name=$(basename "$f" .md)
			model=$(fm_get "$f" model)
			printf "  %-20s %s\n" "$name" "${model:+($model)}"
		done
	done
}

usage() { awk 'NR>1 && /^#/{sub(/^# ?/,""); print; next} NR>1 && !/^#/{exit}' "$0"; }

# ---- dispatch -------------------------------------------------------------

cmd="${1:-}"; shift || true
case "$cmd" in
	doctor)    cmd_doctor "$@" ;;
	run)       cmd_run   "$@" ;;
	tell)      cmd_tell  "$@" ;;
	wait)      cmd_wait  "$@" ;;
	events)    cmd_events "$@" ;;
	reap)      cmd_reap  "$@" ;;
	status)    cmd_status "$@" ;;
	peek)      cmd_peek  "$@" ;;
	ls|list)   cmd_ls    "$@" ;;
	stop|kill) cmd_stop  "$@" ;;
	roles)     cmd_roles "$@" ;;
	""|-h|--help|help) usage ;;
	*) die "unknown command '$cmd' (try: subagents --help)" ;;
esac
