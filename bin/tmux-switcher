#!/usr/bin/env bash

# tmux-switcher - tmux session switcher.
#
# Lists tmux sessions with their worktree name and git branch, and jumps to the
# selected session. Modeled on `m` (bin/m) and designed to run inside a tmux
# popup, e.g. from ~/.config/tmux/tmux.conf:
#
#   bind -n M-s display-popup -E -b rounded -w 45% -h 50% "$HOME/dotfiles/bin/tmux-switcher"

set -u

PADDING="${TMUX_SWITCHER_PADDING:-2}"

names=()
paths=()
worktrees=()
branches=()
filtered_indices=()

filter_query=""
filter_active=0
selected=0
scroll=0
alt_screen=0
cursor_hidden=0

COLOR_RESET=""
COLOR_BOLD=""
COLOR_DIM=""
COLOR_MUTED=""
COLOR_TITLE=""
COLOR_ACCENT=""
COLOR_YELLOW=""
COLOR_SELECTED_BG=""
COLOR_BRANCH=""

usage() {
  cat <<'EOF'
Usage: tmux-switcher [--list] [--help]

A tiny tmux session switcher.

It lists tmux sessions with their worktree name and git branch, and jumps to
the selected session. It works best as a tmux popup:

  bind -n M-s display-popup -E -b rounded -w 45% -h 50% "$HOME/dotfiles/bin/tmux-switcher"

Keys:
  type      filter sessions
  /         start filter before typing numbers
  backspace delete filter character
  1-9       jump to that numbered session when filter is empty
  enter     jump to selected session
  ctrl-r    refresh
  esc       cancel

Options:
  --list    print discovered sessions without opening the TUI
  --help    show this help

Environment:
  TMUX_SWITCHER_PADDING  spaces between popup border and content (default: 2)
EOF
}

require_tmux() {
  if ! command -v tmux >/dev/null 2>&1; then
    echo "tmux-switcher: tmux is required" >&2
    exit 1
  fi

  if ! tmux list-sessions >/dev/null 2>&1; then
    echo "tmux-switcher: no tmux server is running" >&2
    exit 1
  fi
}

init_colors() {
  local colors

  [ -z "${NO_COLOR:-}" ] || return
  colors=$(tput colors 2>/dev/null || printf '0')
  [ "$colors" -ge 8 ] || return

  COLOR_RESET=$'\033[0m'
  COLOR_BOLD=$'\033[1m'
  COLOR_DIM=$'\033[2m'
  COLOR_TITLE=$'\033[36m'
  COLOR_ACCENT=$'\033[34m'
  COLOR_YELLOW=$'\033[33m'
  COLOR_BRANCH=$'\033[35m'

  if [ "$colors" -ge 256 ]; then
    COLOR_SELECTED_BG=$'\033[48;5;236m'
  else
    COLOR_SELECTED_BG=$'\033[44m'
  fi

  if [ "$colors" -ge 16 ]; then
    COLOR_MUTED=$'\033[90m'
  else
    COLOR_MUTED="$COLOR_DIM"
  fi
}

short_path() {
  local path="$1"
  if [ -n "${HOME:-}" ]; then
    path="${path/#$HOME/~}"
  fi
  printf '%s' "$path"
}

git_branch() {
  local path="$1"

  [ -n "$path" ] && [ -d "$path" ] || { printf '%s' '-'; return; }
  git -C "$path" symbolic-ref --short -q HEAD 2>/dev/null && return
  git -C "$path" rev-parse --short HEAD 2>/dev/null && return
  printf '%s' '-'
}

# Git has no concept of a worktree "name" - worktrees are identified by path.
# Derive a useful short label: the Shopify `world/trees/<name>` segment when
# present, otherwise the basename of the git worktree top-level (correct for
# normal one-folder-per-worktree repos), falling back to the path basename.
worktree_name() {
  local path="$1" rest top

  [ -n "$path" ] || { printf '%s' '-'; return; }

  rest="${path#*/world/trees/}"
  if [ "$rest" != "$path" ]; then
    printf '%s' "${rest%%/*}"
    return
  fi

  top=$(git -C "$path" rev-parse --show-toplevel 2>/dev/null)
  if [ -n "$top" ]; then
    basename "$top"
    return
  fi

  basename "$path"
}

truncate() {
  local value="$1"
  local width="$2"

  if [ "$width" -le 0 ]; then
    return
  fi

  if [ "${#value}" -le "$width" ]; then
    printf '%s' "$value"
  elif [ "$width" -le 3 ]; then
    printf '%s' "${value:0:$width}"
  else
    printf '%s...' "${value:0:$((width - 3))}"
  fi
}

pad_truncate() {
  local value="$1"
  local width="$2"
  local clipped

  [ "$width" -le 0 ] && return
  clipped=$(truncate "$value" "$width")
  printf '%-*s' "$width" "$clipped"
}

print_padding() {
  printf '%*s' "$PADDING" ''
}

entry_search_text() {
  local index="$1"

  printf '%s %s %s %s' \
    "${names[$index]}" \
    "${worktrees[$index]}" \
    "${paths[$index]}" \
    "${branches[$index]}"
}

entry_matches_filter() {
  local index="$1"

  [ -z "$filter_query" ] && return 0
  entry_search_text "$index" | grep -qiF -- "$filter_query"
}

rebuild_filtered_indices() {
  local i count

  filtered_indices=()
  for ((i = 0; i < ${#names[@]}; i++)); do
    if entry_matches_filter "$i"; then
      filtered_indices+=("$i")
    fi
  done

  count=${#filtered_indices[@]}
  if [ "$selected" -ge "$count" ]; then
    selected=$((count - 1))
  fi
  [ "$selected" -lt 0 ] && selected=0
  [ "$scroll" -lt 0 ] && scroll=0
}

reset_filter_selection() {
  selected=0
  scroll=0
  rebuild_filtered_indices
}

append_filter_char() {
  filter_query="${filter_query}$1"
  filter_active=1
  reset_filter_selection
}

delete_filter_char() {
  [ -n "$filter_query" ] || return
  filter_query="${filter_query%?}"
  reset_filter_selection
}

clear_filter() {
  filter_query=""
  filter_active=0
  reset_filter_selection
}

clear_entries() {
  names=()
  paths=()
  worktrees=()
  branches=()
  filtered_indices=()
}

refresh_entries() {
  local name path

  clear_entries

  while IFS=$'\t' read -r name path _activity; do
    [ -n "${name:-}" ] || continue

    names+=("$name")
    paths+=("${path:-}")
    worktrees+=("$(worktree_name "${path:-}")")
    branches+=("$(git_branch "${path:-}")")
  done < <(
    tmux list-sessions -F '#{session_name}	#{session_path}	#{session_activity}' 2>/dev/null |
      sort -t $'\t' -k3,3nr
  )

  rebuild_filtered_indices
}

print_entries() {
  local i

  printf '%-24s %-22s %s\n' "SESSION" "WORKTREE" "BRANCH"
  for ((i = 0; i < ${#names[@]}; i++)); do
    printf '%-24s %-22s %s\n' \
      "${names[$i]}" \
      "${worktrees[$i]}" \
      "${branches[$i]}"
  done
}

enter_alt_screen() {
  if [ -t 1 ]; then
    tput smcup 2>/dev/null || true
    alt_screen=1
    tput civis 2>/dev/null || true
    cursor_hidden=1
  fi
}

cleanup() {
  if [ "$cursor_hidden" -eq 1 ]; then
    tput cnorm 2>/dev/null || true
  fi
  if [ "$alt_screen" -eq 1 ]; then
    tput rmcup 2>/dev/null || true
  fi
}

render() {
  local rows cols content_cols total count list_height max_start end display_i i line_no number
  local session_width branch_width filter_display row_style row_reset wt_width
  rows=$(tput lines 2>/dev/null || printf '24')
  cols=$(tput cols 2>/dev/null || printf '80')
  content_cols=$((cols - PADDING * 2))
  [ "$content_cols" -lt 20 ] && content_cols="$cols"
  cols="$content_cols"
  total=${#names[@]}
  count=${#filtered_indices[@]}

  tput cup 0 0 2>/dev/null || printf '\033[H'
  printf '\n'

  print_padding
  printf '%s%s' "$COLOR_TITLE$COLOR_BOLD" 'tmux-switcher'
  printf '%s' "$COLOR_RESET"
  if [ -n "$filter_query" ]; then
    printf ' %s(%d/%d)%s' "$COLOR_MUTED" "$count" "$total" "$COLOR_RESET"
  elif [ "$total" -gt 0 ]; then
    printf ' %s(%d)%s' "$COLOR_MUTED" "$total" "$COLOR_RESET"
  fi
  printf '\n'
  print_padding
  printf '%stype filter  backspace erase  enter jump  ^R refresh  esc clear/quit%s\n' "$COLOR_MUTED" "$COLOR_RESET"
  filter_display="$filter_query"
  [ "$filter_active" -eq 1 ] && filter_display="${filter_display}_"
  print_padding
  printf '%sfilter:%s %s%s%s\n\n' "$COLOR_MUTED" "$COLOR_RESET" "$COLOR_ACCENT$COLOR_BOLD" "$filter_display" "$COLOR_RESET"

  if [ "$total" -eq 0 ]; then
    printf '\n'
    print_padding
    printf '%sNo tmux sessions found.%s\n\n' "$COLOR_YELLOW" "$COLOR_RESET"
    print_padding
    printf '%sPress Ctrl-R to refresh or esc to cancel.%s\n' "$COLOR_MUTED" "$COLOR_RESET"
    printf '%s\033[J' "$COLOR_RESET"
    return
  fi

  if [ "$count" -eq 0 ]; then
    printf '\n'
    print_padding
    printf '%sNo matches for filter:%s %s%s%s\n\n' "$COLOR_YELLOW" "$COLOR_RESET" "$COLOR_ACCENT$COLOR_BOLD" "$filter_query" "$COLOR_RESET"
    print_padding
    printf '%sPress backspace or esc to clear the filter.%s\n' "$COLOR_MUTED" "$COLOR_RESET"
    printf '%s\033[J' "$COLOR_RESET"
    return
  fi

  list_height=$((rows - 7))
  [ "$list_height" -lt 1 ] && list_height=1

  if [ "$selected" -lt "$scroll" ]; then
    scroll=$selected
  fi
  if [ "$selected" -ge $((scroll + list_height)) ]; then
    scroll=$((selected - list_height + 1))
  fi
  max_start=$((count - list_height))
  [ "$max_start" -lt 0 ] && max_start=0
  [ "$scroll" -gt "$max_start" ] && scroll=$max_start
  [ "$scroll" -lt 0 ] && scroll=0

  end=$((scroll + list_height))
  [ "$end" -gt "$count" ] && end=$count

  if [ "$cols" -ge 100 ]; then
    session_width=22
    wt_width=22
  elif [ "$cols" -ge 80 ]; then
    session_width=18
    wt_width=18
  else
    session_width=14
    wt_width=14
  fi
  # number(2) + space + session + space + worktree + space + branch
  branch_width=$((cols - 3 - session_width - 1 - wt_width - 1))
  [ "$branch_width" -lt 0 ] && branch_width=0

  print_padding
  printf '%s%s' "$COLOR_MUTED" "$COLOR_BOLD"
  printf '   '
  pad_truncate 'SESSION' "$session_width"
  printf ' '
  pad_truncate 'WORKTREE' "$wt_width"
  printf ' '
  pad_truncate 'BRANCH' "$branch_width"
  printf '%s\n' "$COLOR_RESET"

  for ((display_i = scroll; display_i < end; display_i++)); do
    i="${filtered_indices[$display_i]}"
    line_no=$((display_i + 1))
    row_style=""
    row_reset=""
    if [ "$display_i" -eq "$selected" ]; then
      row_style="$COLOR_SELECTED_BG$COLOR_BOLD"
      row_reset="$COLOR_RESET"
    fi
    number=' '
    [ "$line_no" -le 9 ] && number="$line_no"

    print_padding
    printf '%s %s ' "$row_style" "$number"
    pad_truncate "${names[$i]}" "$session_width"
    printf ' '
    pad_truncate "${worktrees[$i]}" "$wt_width"
    printf ' '
    printf '%s' "$COLOR_BRANCH"
    pad_truncate "${branches[$i]}" "$branch_width"
    printf '%s%s' "$COLOR_RESET" "$row_style"
    printf '%s\n' "$row_reset"
  done

  printf '%s\033[J' "$COLOR_RESET"
}

jump_to() {
  local index="$1"
  local session="${names[$index]}"

  if [ -n "${TMUX:-}" ]; then
    tmux switch-client -t "$session"
  else
    exec tmux attach-session -t "$session"
  fi
}

jump_to_filtered_index() {
  local display_index="$1"

  [ "$display_index" -lt "${#filtered_indices[@]}" ] || return
  jump_to "${filtered_indices[$display_index]}"
}

move_down() {
  local count=${#filtered_indices[@]}
  [ "$count" -eq 0 ] && return
  selected=$(((selected + 1) % count))
}

move_up() {
  local count=${#filtered_indices[@]}
  [ "$count" -eq 0 ] && return
  selected=$(((selected + count - 1) % count))
}

run_tui() {
  local key seq target

  enter_alt_screen
  init_colors
  trap cleanup EXIT INT TERM

  refresh_entries

  while true; do
    render

    IFS= read -rsn1 key || exit 0
    case "$key" in
      $'\022')
        refresh_entries
        ;;
      /)
        if [ "$filter_active" -eq 1 ]; then
          append_filter_char "$key"
        else
          filter_active=1
        fi
        ;;
      $'\177'|$'\b')
        delete_filter_char
        ;;
      $'\025')
        clear_filter
        ;;
      $'\003')
        exit 0
        ;;
      '')
        if [ "${#filtered_indices[@]}" -gt 0 ]; then
          jump_to_filtered_index "$selected"
          exit 0
        fi
        ;;
      $'\r')
        if [ "${#filtered_indices[@]}" -gt 0 ]; then
          jump_to_filtered_index "$selected"
          exit 0
        fi
        ;;
      [1-9])
        if [ "$filter_active" -eq 1 ]; then
          append_filter_char "$key"
        else
          target=$((key - 1))
          if [ "$target" -lt "${#filtered_indices[@]}" ]; then
            jump_to_filtered_index "$target"
            exit 0
          fi
        fi
        ;;
      $'\e')
        seq=""
        if IFS= read -rsn2 -t 0.05 seq; then
          case "$seq" in
            '[A') move_up ;;
            '[B') move_down ;;
            *) exit 0 ;;
          esac
        else
          exit 0
        fi
        ;;
      [[:print:]])
        append_filter_char "$key"
        ;;
    esac
  done
}

main() {
  local mode="tui"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --help|-h)
        usage
        exit 0
        ;;
      --list|-l)
        mode="list"
        shift
        ;;
      *)
        echo "tmux-switcher: unknown option: $1" >&2
        usage >&2
        exit 2
        ;;
    esac
  done

  require_tmux

  if [ "$mode" = "list" ]; then
    refresh_entries
    print_entries
    exit 0
  fi

  run_tui
}

main "$@"
